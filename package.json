{
  "name": "@neonwave/neonos-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "NeonOS — an open-source AI-native developer environment for repo setup, agent configuration, local memory, and repeatable coding workflows.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neonwave-dev/neon-os.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo build",
    "test": "turbo test && cargo test --workspace",
    "lint": "pnpm lint:ts && cargo clippy --workspace --all-targets -- -D warnings",
    "lint:ts": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "pnpm format:ts && pnpm format:rust",
    "format:ts": "eslint . --fix",
    "format:rust": "cargo fmt --all",
    "check": "pnpm check:ts && pnpm check:rust",
    "check:rust": "cargo fmt --all --check && cargo clippy --workspace --all-targets -- -D warnings && cargo test --workspace",
    "check:ts": "pnpm typecheck && pnpm lint:ts && pnpm build"
  },
  "keywords": [
    "ai",
    "developer-tools",
    "cli",
    "rust",
    "typescript",
    "monorepo",
    "turborepo",
    "claude",
    "local-first",
    "open-source"
  ],
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.9.2",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "turbo": "^2.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  }
}
